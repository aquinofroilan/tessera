# Backend API the Next.js server calls. Server-side only — do not prefix NEXT_PUBLIC_.
# Must include the backend's context-path (server.servlet.context-path, default /api).
BACKEND_API_URL=http://localhost:8080/api

# Optional. Request timeout in milliseconds (default 10000).
BACKEND_API_TIMEOUT_MS=10000

# Optional. Bearer token for service-to-service auth with the backend.
BACKEND_API_TOKEN=
